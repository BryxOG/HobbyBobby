# Корневой gitignore монорепо.
# У каждого сервиса свой .gitignore рядом с его кодом (см. frontend/.gitignore) —
# там пути с ведущим слешем якорятся к папке сервиса, а не к корню репо.

# ОС и редакторы
.DS_Store
Thumbs.db
*.swp
.idea/
*.iml

# Секреты — на любом уровне
.env
.env.*
!.env.example

# Java / Spring (для будущих event-service, user-service)
target/
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# Python (для будущих сервисов)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Логи
*.log
