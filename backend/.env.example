# Postgres (docker compose)
POSTGRES_PORT=5433
POSTGRES_USER=hobbybobby
POSTGRES_PASSWORD=hobbybobby

# Keycloak (docker compose)
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/hobbybobby

# Spring Boot datasource (локальный запуск через Gradle)
EVENTSERVICE_DB_URL=jdbc:postgresql://localhost:5433/eventservice
USERSERVICE_DB_URL=jdbc:postgresql://localhost:5433/userservice
DB_USERNAME=hobbybobby
DB_PASSWORD=hobbybobby

# Gateway (локальный запуск через Gradle)
GATEWAY_PORT=9000
EVENT_SERVICE_URL=http://localhost:9001
USER_SERVICE_URL=http://localhost:9002
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Запуск:
#   cd backend && cp .env.example .env
#   docker compose up -d
#   cd gateway && ./gradlew bootRun       # :9000
#   cd eventservice && ./gradlew bootRun   # :9001
#   cd userservice && ./gradlew bootRun    # :9002
