# Postgres (docker compose): на хосте порт 5433, внутри контейнера 5432
POSTGRES_USER=hobbybobby
POSTGRES_PASSWORD=hobbybobby

# Spring Boot datasource (локальный Gradle bootRun → хост :5433)
DB_USERNAME=hobbybobby
DB_PASSWORD=hobbybobby

# Kafka (docker compose)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Firebase (notification-service)
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
NOTIFICATION_SERVICE_BASE_URL=http://localhost:9004/notificationservice/api

# EventService → UserService (обогащение author)
USER_SERVICE_BASE_URL=http://localhost:9002/userservice/api

# Фронт: NEXT_PUBLIC_USE_MOCK_EVENTS=false — ивенты/карта/теги из EventService
# NEXT_PUBLIC_USE_MOCK_CHATS=false — чаты из EventService
# NEXT_PUBLIC_USE_MOCK_USERS=false — профиль из UserService

# Текущий пользователь до JWT: заголовок X-User-Id (см. userservice test data)
# DEV_CURRENT_USER_ID=1

# Полный стек в Docker (без notification-service):
#   cp backend/.env.example backend/.env
#   docker compose up --build
#
# Только Postgres + Kafka для локальной разработки:
#   cd backend && docker compose up -d
#   cd eventservice && ./gradlew bootRun      # :9011 (9001 часто занят trantorAgent)
#   cd eventservice && ./scripts/seed-events.sh  # 20 тестовых ивентов
#   cd userservice && ./gradlew bootRun       # :9002
#   cd realtime-service && ./gradlew bootRun  # :9003
