    {
      "id": "9LfTKNwdsjhKylsm4kiaV",
      "type": "text",
      "x": -4300.204334979864,
      "y": -402.518473266673,
      "width": 77.22199260952121,
      "height": 37.92542270151806,
      "angle": 0,
      "strokeColor": "#ffffff",
      "backgroundColor": "#000",
